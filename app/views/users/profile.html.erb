<div class="max-w-3xl mx-auto px-4 py-8 space-y-8">

  <% if flash[:alert] %>
    <div class="flex items-center gap-2 px-4 py-3 rounded-lg text-sm font-medium border border-red-500/30 bg-red-500/10 text-red-300">
      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <%= flash[:alert] %>
    </div>
  <% end %>

  <% if flash[:notice] %>
    <div class="flex items-center gap-2 px-4 py-3 rounded-lg text-sm font-medium border border-emerald-500/30 bg-emerald-500/10 text-emerald-300">
      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
      <%= flash[:notice] %>
    </div>
  <% end %>

  <div class="flex items-center gap-5">
    <div class="w-14 h-14 rounded-xl bg-accent/15 flex items-center justify-center text-accent text-xl font-bold ring-1 ring-accent/25 flex-shrink-0">
      <%= @user.name.first.upcase %>
    </div>
    <div>
      <h2 class="text-2xl font-semibold text-text-1 leading-tight"><%= @user.name %></h2>
      <p class="text-sm text-text-4"><%= @user.email_address %></p>
    </div>
  </div>

  <section class="rounded-xl bg-white/[0.02] ring-1 ring-white/[0.04] p-6 space-y-5">
    <h3 class="text-sm font-semibold uppercase tracking-wider text-text-4">Account</h3>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="space-y-1.5">
        <label class="text-xs font-medium text-text-4 uppercase tracking-wider">Name</label>
        <%= tag.input value: @user.name, readonly: true,
          class: "w-full px-3 py-2.5 rounded-lg bg-white/[0.03] border border-white/[0.06] text-text-2 text-sm readonly:text-text-3 focus:outline-none focus:border-accent/40 transition-colors" %>
      </div>
      <div class="space-y-1.5">
        <label class="text-xs font-medium text-text-4 uppercase tracking-wider">Email</label>
        <%= tag.input value: @user.email_address, readonly: true,
          class: "w-full px-3 py-2.5 rounded-lg bg-white/[0.03] border border-white/[0.06] text-text-2 text-sm readonly:text-text-3 focus:outline-none focus:border-accent/40 transition-colors" %>
      </div>
    </div>

    <div class="flex items-center justify-between gap-4 pt-2 border-t border-white/[0.04]">
      <div>
        <p class="text-sm font-medium text-text-2">Password</p>
        <p class="text-xs text-text-4 mt-0.5">Change your account password</p>
      </div>
      <%= link_to edit_password_path(token: @user.password_reset_token),
        class: "flex-shrink-0 inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium border border-white/[0.08] text-text-3 hover:text-text-1 hover:border-white/[0.12] hover:bg-white/[0.02] transition-colors" do %>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
        Reset
      <% end %>
    </div>
  </section>

  <section
    class="rounded-xl bg-white/[0.02] ring-1 ring-white/[0.04] p-6 space-y-5"
    data-controller="api-key-form"
    data-api-key-form-saved-model-value="<%= @user.model %>"
  >
    <h3 class="text-sm font-semibold uppercase tracking-wider text-text-4">AI Configuration</h3>

    <% if @user.ai_configured? %>
      <div class="flex items-center justify-between gap-4">
        <div class="flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-emerald-400 flex-shrink-0"></span>
          <span class="text-sm text-text-2">
            <%= @user.provider.titleize %> · <%= @user.model %>
          </span>
        </div>
        <%= form_with model: @user, url: update_api_key_users_path, method: :patch do |form| %>
          <%= form.hidden_field :api_key, value: "" %>
          <%= form.submit "Remove",
            class: "px-4 py-1.5 rounded-lg text-xs font-medium border border-red-500/20 text-red-400 hover:bg-red-500/10 hover:border-red-500/30 transition-colors cursor-pointer",
            data: { confirm: "Remove AI configuration?" } %>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-text-4">No AI configuration saved</p>
    <% end %>

    <%= form_with(model: @user, url: update_api_key_users_path, method: :patch, local: true,
          html: { id: "api-key-form" }) do |form| %>
      <div class="space-y-3">
        <div class="grid grid-cols-2 gap-3">
          <div class="space-y-1.5">
            <label class="text-xs font-medium text-text-4 uppercase tracking-wider">Provider</label>
            <%= form.select :provider,
              User::PROVIDERS.map { |p| [p.titleize, p] },
              { selected: @user.provider },
              { id: "provider-select",
                class: "w-full px-3 py-2.5 rounded-lg bg-white/[0.03] border border-white/[0.06] text-text-2 text-sm focus:outline-none focus:border-accent/40 transition-colors appearance-none",
                data: { "api-key-form-target": "provider", action: "change->api-key-form#providerChanged" } } %>
          </div>
          <div class="space-y-1.5">
            <label class="text-xs font-medium text-text-4 uppercase tracking-wider">Model</label>
            <%= form.select :model,
              [],
              {},
              { id: "model-select",
                class: "w-full px-3 py-2.5 rounded-lg bg-white/[0.03] border border-white/[0.06] text-text-2 text-sm focus:outline-none focus:border-accent/40 transition-colors appearance-none disabled:opacity-40",
                data: { "api-key-form-target": "model" },
                disabled: @user.provider.blank? } %>
          </div>
        </div>

        <div class="space-y-1.5">
          <label class="text-xs font-medium text-text-4 uppercase tracking-wider">
            <%= @user.ai_configured? ? "Update key" : "Add key" %>
          </label>
          <div class="flex gap-2">
            <%= form.password_field :api_key,
              placeholder: @user.ai_configured? ? "•••••••••••• (enter new to change)" : "sk-...",
              class: "flex-1 px-3 py-2.5 rounded-lg bg-white/[0.03] border border-white/[0.06] text-text-2 text-sm placeholder:text-text-4/50 focus:outline-none focus:border-accent/40 transition-colors",
              data: { "api-key-form-target": "apiKey" } %>
            <%= form.submit "Save",
              class: "px-5 py-2.5 rounded-lg text-sm font-medium bg-accent/90 text-white hover:bg-accent transition-colors cursor-pointer" %>
            <button type="button"
              class="px-5 py-2.5 rounded-lg text-sm font-medium border border-white/[0.08] text-text-3 hover:text-text-1 hover:border-white/[0.12] hover:bg-white/[0.02] transition-colors cursor-pointer disabled:opacity-40"
              data-action="click->api-key-form#testKey"
              data-api-key-form-target="testBtn">
              <span data-api-key-form-target="testLabel">Test</span>
              <span data-api-key-form-target="testSpinner" class="hidden">
                <svg class="animate-spin h-4 w-4 inline" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
              </span>
            </button>
          </div>
          <div data-api-key-form-target="testResult" class="hidden text-xs mt-1"></div>
        </div>
      </div>
    <% end %>
  </section>

  <section class="rounded-xl bg-white/[0.02] ring-1 ring-white/[0.04] p-6 space-y-5">
    <h3 class="text-sm font-semibold uppercase tracking-wider text-text-4">Data</h3>

    <div class="flex flex-col sm:flex-row gap-4">
      <div class="flex-1 space-y-2">
        <p class="text-sm font-medium text-text-2">Export OPML</p>
        <p class="text-xs text-text-4">Back up your subscriptions or migrate to another reader.</p>
        <%= link_to export_opml_users_path,
          class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium bg-accent/90 text-white hover:bg-accent transition-colors mt-3" do %>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          Export
        <% end %>
      </div>

      <div class="hidden sm:block w-px bg-white/[0.04]"></div>

      <div class="flex-1 space-y-2">
        <p class="text-sm font-medium text-text-2">Import OPML</p>
        <p class="text-xs text-text-4">Bring your subscriptions from another reader.</p>
        <%= form_with(url: import_via_opml_user_path, local: true, method: :post, enctype: "multipart/form-data") do |form| %>
          <div class="flex items-center gap-2 mt-3">
            <%= form.file_field :opml_file, accept: ".opml", required: true,
              class: "flex-1 text-xs text-text-3 file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:text-xs file:font-medium file:border file:border-white/[0.08] file:bg-transparent file:text-text-3 file:hover:bg-white/[0.04] file:transition-colors file:cursor-pointer" %>
            <%= form.submit "Import",
              class: "flex-shrink-0 px-4 py-2 rounded-lg text-sm font-medium border border-white/[0.08] text-text-3 hover:text-text-1 hover:border-white/[0.12] hover:bg-white/[0.02] transition-colors cursor-pointer" %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="flex items-center justify-between gap-4 pt-2 border-t border-white/[0.04]">
      <div>
        <p class="text-sm font-medium text-text-2">Clear old articles</p>
        <p class="text-xs text-text-4 mt-0.5">Remove read articles older than a month</p>
      </div>
      <%= button_to clear_old_articles_user_path(@user), method: :delete,
        class: "flex-shrink-0 px-4 py-2 rounded-lg text-xs font-medium border border-red-500/20 text-red-400 hover:bg-red-500/10 hover:border-red-500/30 transition-colors",
        data: { confirm: "Delete all read articles older than 30 days?" } do %>
        Clear
      <% end %>
    </div>
  </section>

  <section class="rounded-xl bg-white/[0.02] ring-1 ring-white/[0.04] p-6 space-y-5">
    <h3 class="text-sm font-semibold uppercase tracking-wider text-text-4">Integrations</h3>

    <div class="space-y-4">
      <h4 class="text-sm font-medium text-text-2">Raindrop.io</h4>

      <% if @raindrop_account.present? %>
        <div class="flex items-center justify-between gap-4">
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-emerald-400 flex-shrink-0"></span>
            <span class="text-sm text-text-3">
              Connected <%= @raindrop_account.connected_at.strftime("%b %d, %Y") %>
            </span>
          </div>
          <%= button_to oauth_raindrop_disconnect_path, method: :delete,
            class: "px-4 py-1.5 rounded-lg text-xs font-medium border border-red-500/20 text-red-400 hover:bg-red-500/10 hover:border-red-500/30 transition-colors",
            data: { confirm: "Disconnect from Raindrop.io?", turbo_confirm: "Disconnect from Raindrop.io?" } do %>
            Disconnect
          <% end %>
        </div>
      <% else %>
        <div class="flex items-center justify-between gap-4">
          <p class="text-sm text-text-4">Save articles directly to your Raindrop collections.</p>
          <%= link_to oauth_raindrop_connect_path,
            class: "flex-shrink-0 inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium bg-blue-600/90 text-white hover:bg-blue-600 transition-colors" do %>
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
            Connect
          <% end %>
        </div>
      <% end %>
    </div>
  </section>

  <div class="pb-12"></div>
</div>
