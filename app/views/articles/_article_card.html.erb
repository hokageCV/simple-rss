<div class="group relative bg-baseBg-5/30 rounded-xl overflow-hidden border border-baseBg-3/20 hover:border-accent/40 hover:shadow-lg hover:shadow-accent/5 transition-all duration-300 hover:-translate-y-0.5" id="<%= dom_id(article) %>">
  <%= link_to article, data: { turbo: false }, class: "block" do %>
    <div class="aspect-video overflow-hidden bg-baseBg-8/60">
      <% if article.image_url.present? %>
        <%= image_tag article.image_url,
            alt: article.title,
            class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500",
            loading: "lazy" %>
      <% else %>
        <div class="w-full h-full flex items-center justify-center">
          <svg class="w-12 h-12 text-baseBg-3/40" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/>
          </svg>
        </div>
      <% end %>
    </div>
  <% end %>

  <turbo-frame id="article_button_<%= article.id %>"
    class="absolute top-2.5 right-2.5 opacity-0 group-hover:opacity-100 transition-opacity flex items-center gap-1.5">
    <div class="relative flex flex-col items-center group/button">
      <%= button_to toggle_status_article_path(article, source: "list_view"),
        method: :patch,
        form: { data: { turbo_stream: true, controller: "optimistic-remove" } },
        class: "p-0 align-baseline inline relative",
        form_class: "inline" do %>
        <span class="w-7 h-7 flex items-center justify-center rounded-full bg-baseBg-8/80 backdrop-blur-sm text-text-1 text-xs hover:bg-accent/20 transition-colors">&#x2713;</span>
      <% end %>
      <span class="text-[10px] text-text-4 opacity-0 group-hover/button:opacity-100 transition-opacity whitespace-nowrap mt-0.5">
        Read
      </span>
    </div>
  </turbo-frame>

  <div class="p-3">
    <span class="inline-block px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider bg-red-600/15 text-red-400 rounded mb-1.5">
      YouTube
    </span>

    <%= link_to article, data: { turbo: false }, class: "block" do %>
      <h3 class="text-sm font-semibold text-text-1 leading-snug line-clamp-2 mb-1.5 group-hover:text-accent transition-colors">
        <%= article.title %>
      </h3>
    <% end %>

    <div class="flex items-center justify-between text-[11px] text-text-4">
      <span class="truncate max-w-[60%]"><%= article.feed.name %></span>
      <time><%= format_date(article.published_at) %></time>
    </div>
  </div>
</div>
