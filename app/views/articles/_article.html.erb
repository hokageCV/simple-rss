<div
  id="<%= dom_id article %>"
  data-controller="scroll-tracker"
  data-status="<%= article.status %>"
>
  <header class="article-header pb-5">
    <% is_youtube = article.feed.generator == Feed::GENERATORS[:youtube] %>

    <h1 class="text-4xl font-bold">
      <%= link_to article.title, article.url,
          class: 'hover:underline',
          target: (open_article_in_new_tab?(article) ? '_blank' : nil),
          rel: (open_article_in_new_tab?(article) ? 'noopener noreferrer' : nil),
          data: { scroll_tracker_target: 'link' } %>
    </h1>

    <div class="meta text-sm text-gray-500">
      <% if is_youtube %>
        <span class="inline-block px-2 py-0.5 text-xs font-semibold uppercase tracking-wider bg-red-600/20 text-red-400 rounded my-2">
          YouTube
        </span>
      <% end %>

      <p>
        By
        <span class="font-semibold">
          <%= link_to article.feed.name, article.feed %>
        </span>
      </p>
      <p> Published on <time datetime="<%= article.published_at.iso8601 %>"><%= format_date(article.published_at) %></time> </p>
      <p>
        Status:
        <span class=" text-green-600" id="<%= dom_id(article, :status_text) %>">
          <%= article.status.capitalize %>
        </span>
      </p>

      <div class="flex flex-wrap gap-2">
        <%= render partial: "articles/toggle_button", locals: { article: article } %>

        <% if Current.user.raindrop_connected? %>
          <div id="save_to_raindrop_<%= dom_id(article) %>">
            <%= render partial: "articles/raindrop_button", locals: { article: article } %>
          </div>
        <% end %>
      </div>
  </header>

  <%= render_content(article) %>

  <div class="h-1 mt-12" data-scroll-tracker-target="sentinel" ></div>
</div>
