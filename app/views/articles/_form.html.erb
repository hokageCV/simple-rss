<%= form_with(model: article, class: "contents") do |form| %>
  <% if article.errors.any? %>
    <div class="p-4 mb-6 rounded-lg border border-red-500/20 bg-red-500/5 text-red-400">
      <h2 class="text-sm font-medium mb-2"><%= pluralize(article.errors.count, "error") %> prohibited this article from being saved:</h2>
      <ul class="list-disc list-inside text-xs space-y-0.5">
        <% article.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4">
    <%= form.label :feed_id, class: "block text-xs font-medium text-text-4 uppercase tracking-wider mb-1.5" %>
    <%= form.text_field :feed_id, class: "w-full px-3 py-2.5 rounded-lg bg-white/[0.03] border border-white/[0.06] text-text-2 text-sm focus:outline-none focus:border-accent/40 transition-colors" %>
  </div>

  <div class="mb-4">
    <%= form.label :title, class: "block text-xs font-medium text-text-4 uppercase tracking-wider mb-1.5" %>
    <%= form.text_field :title, class: "w-full px-3 py-2.5 rounded-lg bg-white/[0.03] border border-white/[0.06] text-text-2 text-sm focus:outline-none focus:border-accent/40 transition-colors" %>
  </div>

  <div class="mb-4">
    <%= form.label :url, class: "block text-xs font-medium text-text-4 uppercase tracking-wider mb-1.5" %>
    <%= form.text_field :url, class: "w-full px-3 py-2.5 rounded-lg bg-white/[0.03] border border-white/[0.06] text-text-2 text-sm focus:outline-none focus:border-accent/40 transition-colors" %>
  </div>

  <div class="mb-4">
    <%= form.label :published_at, class: "block text-xs font-medium text-text-4 uppercase tracking-wider mb-1.5" %>
    <%= form.datetime_field :published_at, class: "w-full px-3 py-2.5 rounded-lg bg-white/[0.03] border border-white/[0.06] text-text-2 text-sm focus:outline-none focus:border-accent/40 transition-colors" %>
  </div>

  <div class="mb-4">
    <%= form.label :user_id, class: "block text-xs font-medium text-text-4 uppercase tracking-wider mb-1.5" %>
    <%= form.text_field :user_id, class: "w-full px-3 py-2.5 rounded-lg bg-white/[0.03] border border-white/[0.06] text-text-2 text-sm focus:outline-none focus:border-accent/40 transition-colors" %>
  </div>

  <div class="mb-6">
    <%= form.label :status, class: "block text-xs font-medium text-text-4 uppercase tracking-wider mb-1.5" %>
    <%= form.text_field :status, class: "w-full px-3 py-2.5 rounded-lg bg-white/[0.03] border border-white/[0.06] text-text-2 text-sm focus:outline-none focus:border-accent/40 transition-colors" %>
  </div>

  <div class="flex items-center gap-3">
    <%= form.submit class: "px-5 py-2.5 rounded-lg text-sm font-medium bg-accent/90 text-white hover:bg-accent transition-colors cursor-pointer" %>
    <%= link_to "Cancel", article.persisted? ? article_path(article) : articles_path, class: "px-5 py-2.5 rounded-lg text-sm font-medium border border-white/[0.08] text-text-3 hover:text-text-1 hover:border-white/[0.16] transition-colors" %>
  </div>
<% end %>
