<div
  class="group relative mb-2 rounded-lg bg-white/[0.02] hover:bg-white/[0.04] transition-colors duration-200"
  id="<%= dom_id(article) %>"
>
  <div class="flex items-start gap-4 p-4">
    <% if article.image_url.present? %>
      <%= image_tag article.image_url,
          alt: article.title,
          class: "w-[180px] h-[140px] object-cover rounded-md flex-shrink-0",
          loading: "lazy" %>
    <% end %>

    <div class="flex-1 min-w-0">
      <div class="flex items-start flex-wrap">
        <p class="mb-0 text-lg flex-1">
          <%= link_to article.title, article,
              data: { turbo: false },
              class: "text-text-2 hover:text-accent transition-colors leading-snug" %>
          <% if show_author %>
            <span class="text-xs text-text-4 ml-2"><%= article.feed.name %></span>
          <% end %>
        </p>

        <turbo-frame id="article_button_<%= article.id %>"
          class="article-btn opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-opacity flex items-center gap-2">
          <div class="relative flex flex-col items-center group/button">
            <%= button_to toggle_status_article_path(article, source: "list_view"),
              method: :patch,
              form: { data: { turbo_stream: true, controller: "optimistic-remove" } },
              class: "p-0 align-baseline inline relative",
              form_class: "inline" do %>
              <span class="w-7 h-7 flex items-center justify-center rounded-full bg-baseBg-8/80 backdrop-blur-sm text-text-1 text-xs hover:bg-accent/20 transition-colors">&#x2713;</span>
            <% end %>
            <span class="text-[10px] text-text-4 opacity-0 group-hover/button:opacity-100 transition-opacity whitespace-nowrap mt-0.5">
              Read
            </span>
          </div>

          <% if article.content.present? %>
            <div class="relative flex flex-col items-center group/button">
              <%= button_to summary_article_path(article),
                method: :post,
                form: { target: "_blank", class: "inline" },
                class: "p-0 align-baseline inline relative" do %>
                <span class="w-7 h-7 flex items-center justify-center rounded-full bg-baseBg-8/80 backdrop-blur-sm text-text-1 text-xs hover:bg-accent/20 transition-colors">&#x272F;</span>
              <% end %>
              <span class="text-[10px] text-text-4 opacity-0 group-hover/button:opacity-100 transition-opacity whitespace-nowrap mt-0.5">
                Summary
              </span>
            </div>
          <% end %>
        </turbo-frame>
      </div>

      <p class="m-0 p-0 text-sm text-text-3 leading-relaxed line-clamp-2 mt-1">
        <%= truncate(strip_tags(article.description), length: 250, omission: '...') %>
      </p>

      <time class="absolute bottom-3 right-4 text-[11px] text-text-4"><%= format_date(article.published_at) %></time>
    </div>
  </div>
</div>
