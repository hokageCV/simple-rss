<div id="<%= dom_id feed %>" class="group flex items-center gap-4 px-5 py-4 rounded-xl bg-white/[0.02] ring-1 ring-white/[0.04] hover:bg-white/[0.04] transition-colors">
  <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0
    <%= case feed.generator
        when 'youtube' then 'bg-red-500/15 text-red-400'
        when 'reddit' then 'bg-orange-500/15 text-orange-400'
        when 'substack' then 'bg-amber-400/15 text-amber-400'
        else 'bg-accent/15 text-accent' end %>">
    <% case feed.generator
       when 'youtube' %>
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/></svg>
    <% when 'reddit' %>
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><circle cx="9.5" cy="12.5" r="1.5"/><circle cx="14.5" cy="12.5" r="1.5"/><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm6.36 14.83c-1.43-1.43-3.3-2.07-5.36-2.07-.89 0-1.73.11-2.53.31-.26-.11-.54-.2-.84-.27.52-.58.97-1.22 1.33-1.91 1.42.48 2.98.75 4.64.75 1.97 0 3.83-.39 5.44-1.07.25.66.39 1.38.39 2.13 0 1.24-.44 2.3-1.07 3.13z"/></svg>
    <% when 'substack' %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
    <% else %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 5c7.18 0 13 5.82 13 13M6 11a7 7 0 017 7m-6 0a1 1 0 110-2 1 1 0 010 2z"/></svg>
    <% end %>
  </div>

  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-2">
      <%= link_to feed.name, feed, class: "text-sm font-medium text-text-2 hover:text-accent transition-colors truncate" %>
      <% if feed.is_paused %>
        <span class="flex-shrink-0 px-1.5 py-0.5 rounded text-[10px] font-medium bg-amber-500/15 text-amber-400">Paused</span>
      <% end %>
      <% if feed.generator.present? && feed.generator != 'default' %>
        <span class="flex-shrink-0 px-1.5 py-0.5 rounded text-[10px] font-medium bg-white/[0.04] text-text-4"><%= feed.generator.capitalize %></span>
      <% end %>
    </div>
    <p class="text-xs text-text-4 truncate mt-0.5"><%= feed.url %></p>
  </div>

  <div class="flex-shrink-0 text-right">
    <span class="text-xs text-text-4"><%= feed.articles.unread.size %> unread</span>
  </div>
</div>
