<%= form_with(model: feed, class: "contents") do |form| %>
  <% if feed.errors.any? %>
    <div class="p-4 mb-6 rounded-lg border border-red-500/20 bg-red-500/5 text-red-400">
      <h2 class="text-sm font-medium mb-2"><%= pluralize(feed.errors.count, "error") %> prohibited this feed from being saved:</h2>
      <ul class="list-disc list-inside text-xs space-y-0.5">
        <% feed.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4">
    <%= form.label :url, class: "block text-xs font-medium text-text-4 uppercase tracking-wider mb-1.5" %>
    <%= form.text_field :url, class: "w-full px-3 py-2.5 rounded-lg bg-white/[0.03] border border-white/[0.06] text-text-2 text-sm placeholder:text-text-4/50 focus:outline-none focus:border-accent/40 transition-colors" %>
  </div>

  <% if @feed.persisted? %>
    <div class="mb-4">
      <%= form.label :generator, class: "block text-xs font-medium text-text-4 uppercase tracking-wider mb-1.5" %>
      <%= form.select :generator,
        Feed::GENERATORS.map { |key, value| [key.to_s.humanize, value] },
        {},
        class: "custom-select w-full px-3 py-2.5 rounded-lg bg-white/[0.03] border border-white/[0.06] text-text-2 text-sm focus:outline-none focus:border-accent/40 transition-colors"
      %>
    </div>
  <% end %>

  <div class="mb-6 flex items-center gap-3">
    <%= form.check_box :skip_summarization, class: "rounded border-white/[0.08] bg-white/[0.03] text-accent focus:ring-accent" %>
    <%= form.label :skip_summarization, class: "text-sm text-text-3" %>
  </div>

  <div class="flex items-center gap-3">
    <%= form.submit class: "px-5 py-2.5 rounded-lg text-sm font-medium bg-accent/90 text-white hover:bg-accent transition-colors cursor-pointer" %>
    <%= link_to "Cancel", feed.persisted? ? feed_path(feed) : feeds_path, class: "px-5 py-2.5 rounded-lg text-sm font-medium border border-white/[0.08] text-text-3 hover:text-text-1 hover:border-white/[0.16] transition-colors" %>
  </div>
<% end %>
