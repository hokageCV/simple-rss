<% is_youtube = @feed.generator == Feed::GENERATORS[:youtube] %>
<div class="mx-auto <%= is_youtube ? 'w-full max-w-6xl' : 'md:w-2/3 w-full flex' %>">
  <div class="<%= is_youtube ? '' : 'mx-auto' %>">
    <% if notice.present? %>
      <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-lg inline-block" id="notice"><%= notice %></p>
    <% end %>

    <div class="flex flex-col gap-3 mb-6">
      <h2 class="text-3xl"><%= link_to @feed.name, @feed %></h2>
      <div class="flex flex-wrap items-center gap-2">
        <%= button_to update_articles_feed_path(@feed.id),
          method: :patch,
          class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium bg-accent/90 text-white hover:bg-accent transition-colors" do %>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
          Fetch Latest
        <% end %>

        <%= button_to update_articles_feed_path(@feed.id),
          method: :patch,
          params: { include_all_articles: true },
          class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium border border-white/[0.08] text-text-3 hover:text-text-1 hover:border-white/[0.16] transition-colors" do %>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
          </svg>
          Fetch All
        <% end %>

        <%= link_to edit_feed_path(@feed),
          class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium border border-white/[0.08] text-text-3 hover:text-text-1 hover:border-white/[0.16] transition-colors" do %>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
          </svg>
          Edit
        <% end %>

        <% if @feed.is_paused %>
          <%= button_to toggle_pause_feed_path(@feed),
            method: :patch,
            class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium border border-emerald-500/25 text-emerald-400 hover:bg-emerald-500/10 transition-colors" do %>
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Resume
          <% end %>
        <% else %>
          <%= button_to toggle_pause_feed_path(@feed),
            method: :patch,
            class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium border border-amber-500/25 text-amber-400 hover:bg-amber-500/10 transition-colors" do %>
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Pause
          <% end %>
        <% end %>

        <%= button_to @feed,
          method: :delete,
          data: { turbo_confirm: "Sure to delete this feed?" },
          class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium border border-red-500/20 text-red-400 hover:bg-red-500/10 transition-colors" do %>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
          Delete
        <% end %>
      </div>
    </div>

    <% if @articles.present? %>
      <p class="text-2xl mt-10">Articles</p>
      <div id="article-list">
        <% if is_youtube %>
          <%= render "articles/youtube_articles", articles: @articles %>
        <% else %>
          <%= render "articles/articles", articles: @articles %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
